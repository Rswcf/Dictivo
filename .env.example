# Local API dev server
PORT=8787
APP_BASE_URL=http://localhost:1420

# Optional legacy local Fastify database. Production Cloud Fast uses
# Cloudflare D1 through wrangler.api.jsonc, not Postgres.
DATABASE_URL=

# Cloud Fast transcription providers
GROQ_API_KEY=
ELEVENLABS_API_KEY=
CLOUD_FAST_TIMEOUT_MS=10000
CLOUD_FAST_MONTHLY_SECONDS=90000
CLOUD_FAST_SESSION_SECRET=

# Lemon Squeezy Cloud Fast license allowlist. Leave blank to accept licenses
# whose product or variant name contains "Cloud Fast".
LEMON_SQUEEZY_CLOUD_FAST_PRODUCT_IDS=
LEMON_SQUEEZY_CLOUD_FAST_VARIANT_IDS=

# Legacy Stripe billing endpoint. The marketing upgrade flow uses the
# /cloud-fast page plus Lemon Squeezy checkout links instead.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_CLOUD_FAST_MONTHLY=
STRIPE_WEBHOOK_SECRET=
