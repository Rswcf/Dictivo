{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictivo",
  "version": "0.1.0",
  "identifier": "com.dictivo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dictivo",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "companion",
        "title": "Dictivo Companion",
        "width": 372,
        "height": 164,
        "minWidth": 332,
        "minHeight": 148,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/private-fast": "private-fast"
    },
    "shortDescription": "Local-first voice dictation",
    "longDescription": "Dictivo turns speech into polished text with an on-device dictation engine for macOS and Windows."
  }
}
