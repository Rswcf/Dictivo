{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictivo",
  "version": "0.2.4",
  "identifier": "com.dictivo.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Dictivo",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "companion",
        "title": "Dictivo Companion",
        "width": 92,
        "height": 92,
        "minWidth": 92,
        "minHeight": 92,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src ipc: http://ipc.localhost",
      "devCsp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/private-fast": "private-fast",
      "resources/benchmark-5s.wav": "benchmark-5s.wav"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Local-first voice dictation",
    "longDescription": "Dictivo turns speech into polished text with an on-device dictation engine for macOS and Windows."
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk2M0EyRTVBQjE2NUZGNTYKUldSVy8yV3hXaTQ2bHZJQXRZeFcranBjbW5OTlk2MjBOYU1Wd0FiK004Y1VRZ0pjYlY1ZTNBbHgK",
      "endpoints": [
        "https://github.com/Rswcf/Dictivo/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["dictivo"]
      }
    }
  }
}
