{
  "name": "@dictivo/api",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "npx wrangler dev --config ../../wrangler.api.jsonc",
    "deploy:worker": "npx wrangler deploy --config ../../wrangler.api.jsonc",
    "d1:create": "npx wrangler d1 create dictivo-api",
    "d1:migrate:local": "npx wrangler d1 migrations apply dictivo-api --local --config ../../wrangler.api.jsonc",
    "d1:migrate:remote": "npx wrangler d1 migrations apply dictivo-api --remote --config ../../wrangler.api.jsonc",
    "build": "npm run build -w @dictivo/shared && node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.check.json",
    "lint": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dictivo/shared": "^0.3.5",
    "@fastify/cors": "^11.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "stripe": "^20.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
